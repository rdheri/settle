{
  "name": "settle",
  "version": "0.0.0",
  "private": true,
  "description": "Settle — a financial-grade double-entry ledger service with idempotency, exactly-once money movement, and a fault-injection proof harness.",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "migrate": "pnpm --filter @settle/api migrate",
    "dev": "pnpm --filter @settle/api dev",
    "harness": "pnpm --filter @settle/api harness"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.0"
  }
}
