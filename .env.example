# --- Database (matches docker-compose.yml) ---
# Host port 5433 is used to avoid clashing with a local/Homebrew Postgres on 5432.
DATABASE_URL=postgres://settle:settle@localhost:5433/settle

# --- API server ---
PORT=3000
HOST=0.0.0.0

# --- Concurrency / exactly-once tuning ---
# Bounded retry budget for SERIALIZABLE transactions on 40001 serialization failures.
TX_MAX_RETRIES=5
# Base backoff (ms) between serialization-failure retries (exponential + jitter).
TX_RETRY_BASE_MS=10

# An in_progress idempotency key older than this is considered abandoned (crashed
# request) and may be reclaimed by a retry. Keep small in tests, larger in prod.
IDEMPOTENCY_STALE_MS=15000

# --- Outbox poller ---
# How often the outbox poller scans for unpublished events (ms).
OUTBOX_POLL_INTERVAL_MS=500
# Max events drained per poll tick.
OUTBOX_BATCH_SIZE=100
